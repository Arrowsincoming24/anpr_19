# ANPR Vision — Environment Variables
# Copy this file to .env and fill in values

# Kaggle API credentials (get from https://www.kaggle.com/account)
# Alternatively, place ~/.kaggle/kaggle.json
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# Backend server settings
PORT=8000
HOST=0.0.0.0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
